<!DOCTYPE html>
<html lang="es" class="h-full overflow-hidden">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Módulo 2: Lavado de Activos - RAMUX</title>

    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;500;700;900&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css">

    <script>
        tailwind.config = {
            theme: {
                extend: {
                    fontFamily: { sans: ['Outfit', 'sans-serif'
                ]
            },
                    colors: {
                        ramux: '#0ea5e9', /* Azul Principal */
                        ramuxvis: '#8b5cf6', /* Violeta Secundario */
                        brand: '#F76B1C', /* Naranja Marca */
                        dark: '#020617', /* Fondo Oscuro */
            },
                    fontSize: {
                        'xs': '0.75rem', /* 12px */
                        'sm': '0.875rem', /* 14px */
                        'base': '1rem', /* 16px */
                        'lg': '1.125rem', /* 18px */
                        'xl': '1.25rem', /* 20px */
                        '2xl': '1.5rem', /* 24px */
                        '3xl': '1.875rem', /* 30px */
                        '4xl': '2.25rem', /* 36px */
                        '5xl': '3rem', /* 48px */
            },
                    animation: {
                        'fade-in': 'fadeIn 0.6s ease-out forwards',
                        'pulse-slow': 'pulse 3s cubic-bezier(0.4,
                0,
                0.6,
                1) infinite',
                        'tracking-in': 'trackingIn 1.5s cubic-bezier(0.215,
                0.610,
                0.355,
                1.000) both',
                        'text-shimmer': 'shimmer 3s ease-in-out infinite alternate',
            },
                    keyframes: {
                        fadeIn: {
                            '0%': { opacity: '0', transform: 'translateY(15px)'
                    },
                            '100%': { opacity: '1', transform: 'translateY(0)'
                    },
                },
                        trackingIn: {
                            '0%': { letterSpacing: '-0.5em', opacity: '0'
                    },
                            '40%': { opacity: '0.6'
                    },
                            '100%': { letterSpacing: 'normal', opacity: '1'
                    },
                },
                        shimmer: {
                            '0%': { textShadow: '0 0 0px rgba(255,
                        255,
                        255,
                        0)'
                    },
                            '100%': { textShadow: '0 0 15px rgba(14,
                        165,
                        233,
                        0.6)'
                    },
                }
            }
        }
    }
}
    </script>
    <style>
        body {
            background-color: #020617;
            color: #f1f5f9;
            overflow-x: hidden;
            /* Prevent horizontal scroll */
}
/* Fondo Premium */
        .fixed-background {
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            z-index: -1;
            background: radial-gradient(circle at top right, #1e1b4b 0%, #0f172a 40%, #020617 100%);
}
/* Paneles de Vidrio Optimizados */
        .glass-nav {
            background: rgba(2,
    6,
    23,
    0.95);
            border-bottom: 1px solid rgba(255,
    255,
    255,
    0.08);
            backdrop-filter: blur(8px);
}

        .glass-panel {
            background: rgba(15,
    23,
    42,
    0.85);
            border: 1px solid rgba(56,
    189,
    248,
    0.15);
            box-shadow: 0 4px 20px rgba(0,
    0,
    0,
    0.2);
            transition: all 0.3s ease;
}
/* ESTILOS DE NIVELES (GAME MAP) */
        .level-card {
            transition: all 0.3s cubic-bezier(0.4,
    0,
    0.2,
    1);
            position: relative;
            overflow: hidden;
}

        .level-card.active {
            background: linear-gradient(90deg, rgba(14,
    165,
    233,
    0.2) 0%, rgba(15,
    23,
    42,
    0) 100%);
            border-left: 4px solid #0ea5e9;
            box-shadow: 0 4px 12px rgba(14,
    165,
    233,
    0.1);
}

        .level-card.locked {
            opacity: 0.5;
            cursor: not-allowed;
            filter: grayscale(0.8);
}

        .level-card.completed .check-icon {
            color: #10b981;
            /* Green */
            text-shadow: 0 0 10px rgba(16,
    185,
    129,
    0.5);
}

        .level-card:hover:not(.locked) {
            transform: translateX(5px);
            background: rgba(255,
    255,
    255,
    0.05);
}
/* TRANSICIONES DE PÁGINA (NIVELES) */
        .level-content {
            display: none;
            /* Hidden by default */
            animation: slideIn 0.5s cubic-bezier(0.16,
    1,
    0.3,
    1);
}

        .level-content.active {
            display: block;
}

        @keyframes slideIn {
            from {
                opacity: 0;
                transform: translateY(20px) scale(0.98);
    }

            to {
                opacity: 1;
                transform: translateY(0) scale(1);
    }
}
/* Tipografía y Lectura */
        .theory-title {
            font-size: 3.5rem;
            font-weight: 800;
            color: white;
            margin-bottom: 1.5rem;
            padding-bottom: 1rem;
            border-bottom: 2px solid rgba(14,
    165,
    233,
    0.3);
            display: flex;
            align-items: center;
            gap: 1rem;
            letter-spacing: -0.02em;
}

        .theory-subtitle {
            font-size: 2.25rem;
            font-weight: 700;
            color: #38bdf8;
            margin-top: 2rem;
            margin-bottom: 1rem;
}

        .theory-text {
            font-size: 1.5rem;
            line-height: 1.8;
            color: #cbd5e1;
            margin-bottom: 1.5rem;
}

        .highlight {
            color: #F76B1C;
            font-weight: 600;
}
/* Scrollbar */
: :-webkit-scrollbar {
            width: 8px;
}

        : :-webkit-scrollbar-track {
            background: #0f172a;
}

        : :-webkit-scrollbar-thumb {
            background: #334155;
            border-radius: 4px;
}

        : :-webkit-scrollbar-thumb:hover {
            background: #0ea5e9;
}
/* HUD - Heads Up Display (User Stats) */
        .hud-stat {
            background: rgba(0,
    0,
    0,
    0.3);
            border: 1px solid rgba(255,
    255,
    255,
    0.1);
            border-radius: 8px;
            padding: 4px 12px;
            display: flex;
            align-items: center;
            gap: 8px;
}
/* Modal de Desafío */
        .challenge-modal {
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            background: rgb(2,
    6,
    23);
            z-index: 9999;
            display: none;
            justify-content: center;
            align-items: flex-start;
            padding-top: 10vh;
            backdrop-filter: blur(10px);
}

        .social-icon {
            transition: all 0.3s ease;
            color: #94a3b8;
}

        .social-icon:hover {
            color: #0ea5e9;
            transform: scale(1.1);
}

        .text-glow {
            transition: text-shadow 0.3s ease;
}

        .group:hover .text-glow {
            text-shadow: 0 0 20px rgba(255,
    255,
    255,
    0.6);
}
    </style>
</head>

