    3: { q: "¿La simulación de licitud es el objetivo final del lavado?", a: true, exp: "Verdadero.", nextLvl: 4
    },
    4: { q: "¿La CNV y la UIF dictan normas de prevención?", a: true, exp: "Verdadero.", nextLvl: 5
    },
    5: { q: "¿La Ley 25.246 es la norma base antilavado?", a: true, exp: "Verdadero.", nextLvl: 6
    },
    6: { q: "¿La colocación es la primera etapa del lavado?", a: true, exp: "Verdadero.", nextLvl: 7
    },
    7: { q: "¿El financiamiento del terrorismo siempre usa fondos ilícitos?", a: false, exp: "Falso. Puede usar fondos lícitos para fines ilícitos.", nextLvl: 8
    },
    8: { q: "¿Los Agentes (ALyC) son Sujetos Obligados ante la UIF?", a: true, exp: "Verdadero.", nextLvl: 9
    },
    9: { q: "¿La UIF es la autoridad de supervisión en materia de lavado?", a: true, exp: "Verdadero.", nextLvl: 10
    },
    10: { q: "¿La justicia penal aplica las sanciones de la Ley?", a: true, exp: "Verdadero.", nextLvl: 11
