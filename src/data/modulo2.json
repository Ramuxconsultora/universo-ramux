                        </div>
                    `;

                case 'highlight_box':
                    return `
                        <div class="bg-slate-800/50 p-6 rounded-2xl border border-slate-700">
                            <h3 class="text-xl font-bold text-ramux mb-4"><i class="fas fa-lightbulb mr-2"></i> ${item.title
