    <script>
        // === GAME CONFIGURATION & DATA ===
        const TOTAL_LEVELS = 11;
        const XP_PER_LEVEL = 100;

        // Data for Level Challenges (The "Boss" of each level)
        const levelData = {
    1: { q: "¿El lavado de activos busca dar apariencia de licitud a fondos ilícitos?", a: true, exp: "Verdadero. Ese es el objetivo principal.", nextLvl: 2
    },
    2: { q: "¿El narcotráfico es un delito precedente del lavado?", a: true, exp: "Verdadero.", nextLvl: 3
