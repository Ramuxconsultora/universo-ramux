    // Level 11 is Bibliografía
};

        // === EXAM DATA (60 QUESTIONS) ===
        const practiceQuestions = [
    { id: 1, q: "El lavado de activos busca legitimar capitales ilícitos.", a: true, exp: "Verdadero. Es el proceso de dar apariencia legal.", ref: 1
    },
    { id: 2, q: "La etapa de colocación introduce los fondos al sistema.", a: true, exp: "Verdadero. Es la primera fase.", ref: 6
    },
    { id: 3, q: "La UIF es el organismo encargado del análisis financiero antilavado.", a: true, exp: "Verdadero.", ref: 9
    },
    { id: 4, q: "El financiamiento del terrorismo solo proviene de fondos ilegales.", a: false, exp: "Falso. Puede ser lícito o ilícito.", ref: 7
    },
    { id: 5, q: "Los bancos deben reportar operaciones sospechosas.", a: true, exp: "Verdadero. Son Sujetos Obligados.", ref: 8
    },
    { id: 6, q: "Un escribano no es sujeto obligado.", a: false, exp: "Falso. Los escribanos son sujetos obligados.", ref: 8
    },
    { id: 7, q: "La estratificación busca complicar el rastreo de fondos.", a: true, exp: "Verdadero.", ref: 6
    },
    { id: 8, q: "La pena por lavado puede incluir prisión.", a: true, exp: "Verdadero.", ref: 10
    },
    { id: 9, q: "La CNV no tiene facultad para dictar normas antilavado.", a: false, exp: "Falso. La CNV dicta normas para el mercado de capitales en concordancia con UIF.", ref: 5
    },
    { id: 10, q: "La autolavado no es punible.", a: false, exp: "Falso. El autolavado también es delito.", ref: 10
    }
];

        // === STATE MANAGEMENT ===
        let gameState = {
            xp: 0,
            currentLevel: 1, // The level the user is currently READING (highest unlocked usually)
            unlockedLevels: 1 // Highest level unlocked
};

        // Initialize
        document.addEventListener('DOMContentLoaded', () => {
            loadGame();
            renderPracticeQuestions();
            updateSidebarLocks(); // Renamed from updateHUD
            // Initial view check
            goToLevel(gameState.currentLevel, false);

            // Sidebar toggle for mobile
            const sidebarToggle = document.getElementById('sidebar-toggle');
            const sidebar = document.getElementById('sidebar');
            if (sidebarToggle && sidebar) {
                sidebarToggle.addEventListener('click', () => {
                    sidebar.classList.toggle('-translate-x-full');
        });
    }
});

        function loadGame() {
            const saved = localStorage.getItem('cnv_m2_gamestate');
            if (saved) {
                gameState = JSON.parse(saved);
    }
    // Ensure data integrity - FORCE UNLOCK ALL LEVELS FOR REVIEW
            if (!gameState.unlockedLevels || gameState.unlockedLevels < 11) gameState.unlockedLevels = 11;

            // Validate user auth
            if (!localStorage.getItem('cnv_auth')) {
        // window.location.href = 'index.html'; // Commented for dev/testing ease if needed
    } else {
        // These are now handled by the standard header JS
    }
}

        function saveGame() {
            localStorage.setItem('cnv_m2_gamestate', JSON.stringify(gameState));
            updateSidebarLocks(); // Renamed from updateHUD
}

        function updateSidebarLocks() { // Renamed from updateHUD
    // document.getElementById('xp-display').innerText = gameState.xp; // Removed
    // document.getElementById('level-display').innerText = gameState.currentLevel; // Removed
    // Update Sidebar Locks
            for (let i = 1; i <= TOTAL_LEVELS; i++) {
                const card = document.getElementById(`card-lvl-${i
        }`);
                if (!card) continue;

                // Reset classes
                card.classList.remove('locked', 'active', 'completed');
                const lockIcon = card.querySelector('.fa-lock');
                const statusIcon = card.querySelector('.status-icon');

                if (i <= gameState.unlockedLevels || i === 11) {
            // Unlocked
                    if (lockIcon) {
                        lockIcon.className = 'fas fa-map-marker-alt text-ramux status-icon';
            }

                    if (i < gameState.unlockedLevels) {
                        card.classList.add('completed');
                        if (statusIcon) {
                            statusIcon.className = 'fas fa-check-circle text-emerald-500 status-icon';
                }
            }
            // Clickable
                    card.onclick = () => goToLevel(i);
        } else {
            // Locked
                    card.classList.add('locked');
                    if (lockIcon) {
                        lockIcon.className = 'fas fa-lock opacity-50 status-icon';
            }
                    card.onclick = null;
        }
    }
    // Active State
            const activeCard = document.getElementById(`card-lvl-${gameState.currentLevel
    }`);
            if (activeCard) {
                activeCard.classList.add('active');
    }
}
// === NAVIGATION ===
        function goToLevel(levelNum, animate = true) {
            if (levelNum > gameState.unlockedLevels && levelNum !== 11) return; // Security check

            // Update State
            gameState.currentLevel = levelNum;
            saveGame(); // Persist current reading position

            // DOM Updates
            document.querySelectorAll('.level-content').forEach(el => {
                el.classList.add('hidden');
                el.classList.remove('active');
    });

            const target = document.getElementById(`level-${levelNum
    }`);
            if (target) {
                target.classList.remove('hidden');
                target.classList.add('active'); // Optional, to keep CSS slideIn if dependent on it
                if (animate) {
                    target.classList.remove('slideIn');
                    void target.offsetWidth; // Trigger reflow
                    target.classList.add('slideIn');
        }
                document.querySelector('main').scrollTo({ top: 0, behavior: 'smooth'
        });
    }
    // Hide Practice, Show Theory
            switchTab('theory');
}

        function switchTab(tab) {
            const t = document.getElementById('theory-content');
            const p = document.getElementById('practice-content');
            const bt = document.getElementById('btn-theory');
            const bp = document.getElementById('btn-practice');
            const nav = document.getElementById('level-map');

            if (tab === 'theory') {
                t.classList.remove('hidden');
                p.classList.add('hidden');
                nav.classList.remove('hidden'); // Show map in theory

                bt.classList.add('bg-ramux', 'text-white', 'shadow-lg');
                bt.classList.remove('text-slate-300');

                bp.classList.remove('bg-ramux', 'text-white', 'shadow-lg');
                bp.classList.add('text-slate-300');
    } else {
                t.classList.add('hidden');
                p.classList.remove('hidden');
                nav.classList.add('hidden'); // Hide map in practice to focus

                bp.classList.add('bg-ramux', 'text-white', 'shadow-lg');
                bp.classList.remove('text-slate-300');

                bt.classList.remove('bg-ramux', 'text-white', 'shadow-lg');
                bt.classList.add('text-slate-300');
    }
}
// === CHALLENGE SYSTEM ===
        function openChallenge(levelNum) {
            const modal = document.getElementById('challenge-modal');
            const content = document.getElementById('modal-content');
            const data = levelData[levelNum
    ];

            if (!data) return;

            // Render Quesion
            content.innerHTML = `
        <div class="text-center mb-8">
            <span
                class="inline-block px-3 py-1 bg-ramux/20 text-ramux rounded-full text-xs font-bold tracking-widest mb-4">DESAFÍO
                NIVEL ${levelNum
    }</span>
            <h3 class="text-2xl md:text-3xl font-black text-white leading-tight">${data.q
